/.rsconstruct/
# build artifacts from the exercises build system (per-exercise outputs in the
# singlecore/ and dualcore/ trees; dual-core also emits *_cm4 / *_cm0p variants)
/exercises/*/*/app*.elf
/exercises/*/*/firmware*.bin
/exercises/*/*/app*.map
/exercises/*/*/.obj/
# shared HAL libraries, compiled once from the STM32CubeWL HAL driver set
# (one per core: M4 and M0+)
/exercises/common/.hal_obj/
/exercises/common/.hal_obj_cm0/
/exercises/common/libhal.a
/exercises/common/libhal_cm0.a
# STM32CubeWL firmware package (HAL/LL/CMSIS), cloned by scripts/clone_cubewl.sh
# into the repo root. External vendor source, never committed.
/STM32CubeWL/
# python __pycache__ folders
__pycache__
# downloaded installers (e.g. STM32CubeIDE)
/download/
*.elf
*.map
*.bin
